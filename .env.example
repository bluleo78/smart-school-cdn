# Smart School CDN 환경 변수 예시
# 운영 서버에서는 ~/prod/smart-school-cdn/.env 파일에 실제 값을 설정한다.

# 캐시 최대 용량 (GB)
CACHE_MAX_SIZE_GB=20

# CDN 서버 IP — DNS가 등록된 도메인에 반환할 IP (학교 네트워크 내 CDN 서버 IP)
CDN_IP=192.168.1.100

# Upstream DNS — 미등록 도메인 포워딩 대상 (기본: 8.8.8.8)
DNS_UPSTREAM=8.8.8.8

# Phase 21: admin-server 인증
# JWT 서명 키 (32+ bytes). 운영 시 필수 — 생성: openssl rand -hex 32
JWT_SECRET=

# proxy ↔ admin-server 내부 호출 토큰 (32+ bytes). 운영 시 필수 — 생성: openssl rand -hex 32
INTERNAL_API_TOKEN=

# 로컬 dev 기본값 예시 (실제 시크릿 아님 — pnpm dev 가 미설정 시 자동 주입):
#   JWT_SECRET=dev-secret-dev-secret-dev-secret-dev
#   INTERNAL_API_TOKEN=dev-internal-token-dev-internal-token-dev
